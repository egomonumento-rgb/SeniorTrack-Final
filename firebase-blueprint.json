{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information including role and senior care details.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["caregiver", "family"] },
        "photoURL": { "type": "string" },
        "linkedSeniorId": { "type": "string", "description": "The UID of the caregiver who manages the senior" },
        "pairingCode": { "type": "string", "description": "Unique code generated by family members to share with caregivers" },
        "linkedFamilyUids": { "type": "array", "items": { "type": "string" }, "description": "List of family members linked to this caregiver (max 2)" },
        "seniorInfo": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "age": { "type": "number" },
            "bloodType": { "type": "string" },
            "chronicDiseases": { "type": "array", "items": { "type": "string" } },
            "allergies": { "type": "array", "items": { "type": "string" } }
          }
        }
      },
      "required": ["uid", "role"]
    },
    "Medication": {
      "title": "Medication",
      "description": "Medication schedule and inventory tracking.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "dosage": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "skipped"] },
        "lastAdministered": { "type": "string", "format": "date-time" },
        "inventoryCount": { "type": "number" },
        "notes": { "type": "string" }
      },
      "required": ["name", "dosage", "time", "status"]
    },
    "Appointment": {
      "title": "Medical Appointment",
      "description": "Scheduled medical appointments.",
      "type": "object",
      "properties": {
        "doctor": { "type": "string" },
        "specialty": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["doctor", "specialty", "date", "time"]
    },
    "VitalSign": {
      "title": "Vital Sign",
      "description": "Health metrics like blood pressure, heart rate, etc.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["bp", "heart", "oxygen", "temp", "weight", "glucose"] },
        "value": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "unit": { "type": "string" }
      },
      "required": ["type", "value", "timestamp"]
    },
    "Geofence": {
      "title": "Geofence Status",
      "description": "Location tracking and safety perimeter status.",
      "type": "object",
      "properties": {
        "center": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "radius": { "type": "number" },
        "status": { "type": "string", "enum": ["safe", "unsafe"] },
        "lastUpdate": { "type": "string", "format": "date-time" },
        "currentLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and senior care data."
    },
    "/users/{userId}/medications/{medId}": {
      "schema": "Medication",
      "description": "Medication schedule for the senior managed by this user/family."
    },
    "/users/{userId}/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Medical appointments for the senior."
    },
    "/users/{userId}/vitals/{vitalId}": {
      "schema": "VitalSign",
      "description": "Health metrics history."
    },
    "/users/{userId}/geofence/status": {
      "schema": "Geofence",
      "description": "Current safety status and location."
    }
  }
}
